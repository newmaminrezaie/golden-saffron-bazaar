# Frontend environment variables.
# Copy to `.env` and fill in real values. Only variables prefixed with VITE_
# are exposed to the browser bundle — never put secrets here.

# Base URL of the separate Zarinpal / Express payment backend.
# The frontend will POST checkout requests to this origin.
VITE_PAYMENT_API_URL=https://payments.example.com

# Public site URL (no trailing slash). Used at build time to generate
# `dist/client/sitemap.xml` and to fill in the `Sitemap:` line of
# `dist/client/robots.txt`. Set this to your real production domain
# before running `npm run build`.
VITE_SITE_URL=https://yourdomain.com
